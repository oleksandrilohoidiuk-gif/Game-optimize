<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>AI Оптимізатор ігор</title>
    <style>
        body { font-family: sans-serif; max-width: 600px; margin: 20px auto; padding: 0 15px; }
        .form-group { margin-bottom: 15px; }
        select, input { width: 100%; padding: 10px; margin-top: 5px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
        button { padding: 12px 20px; cursor: pointer; border-radius: 4px; border: none; font-weight: bold; }
        .btn-submit { background: #28a745; color: white; width: 100%; }
        #loader { display: none; color: #0056b3; font-weight: bold; margin: 15px 0; text-align: center; }
        #error-box { display: none; color: #721c24; background: #f8d7da; padding: 10px; margin-bottom: 15px; border-radius: 4px; }
    </style>
</head>
<body>
    <h2>AI-Асистент: Оптимізація FPS</h2>

    <div id="error-box"></div>
    <div id="loader"> ШІ аналізує конфігурацію... Це може зайняти до 10 секунд.</div>

    <form id="optimizeForm">
        <div class="form-group">
            <label>Введіть назву гри:</label>
            <input type="text" id="game" name="game" placeholder="Наприклад: Cyberpunk 2077, Dota 2..." required>
        </div>

        <div class="form-group">
            <label>Характеристики ПК/Ноутбука:</label>
            <input type="text" id="hardware" name="hardware" placeholder="Наприклад: amd radeon rx7800 xt ryzen 5 5600x 32gb, 3440x1440" required>
        </div>

        <div class="form-group">
            <label>Пріоритет оптимізації:</label>
            <select id="priority" name="priority">
                <option value="продуктивність">Максимальний FPS (Максимальну продуктивність)</option>
                <option value="якість">Найкраща картинка (Якість картинки)</option>
                <option value="баланс">Оптимальний баланс (Стабільний FPS + Гарна графіка)</option>
            </select>
        </div>

        <button type="submit" id="submitBtn" class="btn-submit">Отримати налаштування</button>
    </form>

    <button id="resetBtn" style="margin-top: 20px; background: #dc3545; color: white;">🗑 Очистити форму</button>

    <script>
        const form = document.getElementById('optimizeForm');
        
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const game = document.getElementById('game').value;
            const hardware = document.getElementById('hardware').value;
            const priority = document.getElementById('priority').value;
            
            const btn = document.getElementById('submitBtn');
            const loader = document.getElementById('loader');
            const errorBox = document.getElementById('error-box');

            btn.disabled = true;
            btn.textContent = "Генерація...";
            loader.style.display = 'block';
            errorBox.style.display = 'none';

            try {
                const response = await fetch('/optimize', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ game, hardware, priority })
                });

                if (response.redirected) {
                    window.location.href = response.url;
                    return;
                }
                
                if (!response.ok) throw new Error('Помилка сервера');

            } catch (err) {
                errorBox.textContent = "Сталася помилка. Перевірте підключення або спробуйте пізніше.";
                errorBox.style.display = 'block';
            } finally {
                btn.disabled = false;
                btn.textContent = "Отримати налаштування";
                loader.style.display = 'none';
            }
        });

        document.getElementById('resetBtn').addEventListener('click', () => {
            form.reset();
            document.getElementById('error-box').style.display = 'none';
        });
    </script>
</body>
</html>